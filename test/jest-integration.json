{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": "test/integration/.*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testEnvironment": "node",
  "globalSetup": "<rootDir>/test/helpers/test-db.setup.ts",
  "globalTeardown": "<rootDir>/test/helpers/test-db.teardown.ts",
  "testTimeout": 30000
}
